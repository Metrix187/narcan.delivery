# narcan.delivery — Apache config for Namecheap cPanel shared hosting
# Drop this file in public_html/ alongside index.html.

# ---- Force HTTPS + canonical host -----------------------------------------
RewriteEngine On
RewriteCond %{HTTPS} !=on
RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

# Redirect www -> apex (remove these three lines if you prefer www)
RewriteCond %{HTTP_HOST} ^www\.narcan\.delivery$ [NC]
RewriteRule ^ https://narcan.delivery%{REQUEST_URI} [L,R=301]

# ---- Legacy /?state=XX -> /states/<slug>/ (optional, keeps old links hot) -
# Apache can't easily map CA -> california without a RewriteMap; instead the
# site's JS redirects these in-browser. Leave this section empty on purpose.

# ---- Directory behavior ---------------------------------------------------
DirectoryIndex index.html
Options -Indexes

# ---- Custom 404 (falls back to homepage so the SPA can handle it) ---------
ErrorDocument 404 /index.html

# ---- Compression ----------------------------------------------------------
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/css text/javascript application/javascript application/json application/xml image/svg+xml
</IfModule>

# ---- Cache headers --------------------------------------------------------
<IfModule mod_expires.c>
  ExpiresActive On
  # HTML: short cache so content updates propagate
  ExpiresByType text/html "access plus 10 minutes"
  # Fingerprint these in the future if you ever add build hashes
  ExpiresByType text/css "access plus 7 days"
  ExpiresByType application/javascript "access plus 7 days"
  ExpiresByType image/svg+xml "access plus 30 days"
  ExpiresByType image/png "access plus 30 days"
  ExpiresByType application/json "access plus 1 hour"
</IfModule>

# ---- Security headers -----------------------------------------------------
<IfModule mod_headers.c>
  Header set X-Content-Type-Options "nosniff"
  Header set Referrer-Policy "strict-origin-when-cross-origin"
  Header set Permissions-Policy "interest-cohort=()"
  Header set Strict-Transport-Security "max-age=31536000; includeSubDomains" env=HTTPS
</IfModule>

# ---- MIME (most cPanel hosts already set these; harmless duplicates) ------
AddType application/json .json
AddType image/svg+xml .svg
AddType application/xml .xml
